    RowBox[{"{", 
     RowBox[{"w_", ",", "w0_", ",", "w1_"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"OptionsPattern", "[", 
     RowBox[{"{", 
