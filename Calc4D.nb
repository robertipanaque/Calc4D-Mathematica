                    RowBox[{"{", 
                    RowBox[{"w", ",", "w0", ",", "w1", ",", "dw"}], "}"}]}], 
                    "]"}]}], ";", "\[IndentingNewLine]", 
                   RowBox[{"{", 
                    RowBox[{"style", ",", 
                    RowBox[{"MakePolyhedrons", "[", "aux", "]"}]}], "}"}]}]}],
                  "]"}]}], "]"}], ",", "\[IndentingNewLine]", 
              RowBox[{"{", 
               RowBox[{"flist", ",", "points", ",", "styles"}], "}"}]}], 
             "]"}], ",", 
            RowBox[{"Lighting", "->", "\"\<Neutral\>\""}]}], "]"}], ",", 
