              RowBox[{"{", 
               RowBox[{"0.", ",", "1.", ",", "0.", ",", "0."}], "}"}]}], 
             "}"}]}], "]"}], ".", 
          RowBox[{"RotationMatrix", "[", 
           RowBox[{"\[Theta]2", ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"1.", ",", "0.", ",", "0.", ",", "0."}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"0.", ",", "0.", ",", "1.", ",", "0."}], "}"}]}], 
             "}"}]}], "]"}], ".", 
          RowBox[{"RotationMatrix", "[", 
           RowBox[{"\[Theta]3", ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"1.", ",", "0.", ",", "0.", ",", "0."}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"0.", ",", "0.", ",", "0.", ",", "1."}], "}"}]}], 
             "}"}]}], "]"}], ".", 
          RowBox[{"RotationMatrix", "[", 
           RowBox[{"\[Theta]4", ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"0.", ",", "1.", ",", "0.", ",", "0."}], "}"}], ",", 
              RowBox[{"{", 
