          RowBox[{"Boxed", "->", "False"}], ",", 
          RowBox[{"Axes", "->", "False"}], ",", 
          RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]1", ",", "0.", ",", 
