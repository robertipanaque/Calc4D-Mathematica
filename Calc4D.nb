                 RowBox[{"OptionValue", "[", "AxesLength", "]"}], ",", "R"}], 
                "]"}], ",", "Nothing"}], "]"}], ",", 
             RowBox[{"Lighting", "->", "\"\<Neutral\>\""}]}], "}"}], "]"}], ",",
           "\[IndentingNewLine]", 
          RowBox[{"Graphics3D", "[", 
           RowBox[{
            RowBox[{"MapThread", "[", 
             RowBox[{
              RowBox[{"Function", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"f", ",", "pp", ",", "style"}], "}"}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{"Module", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"d1", "=", 
                    RowBox[{"pp", "[", 
                    RowBox[{"[", "1", "]"}], "]"}]}], ",", 
                    RowBox[{"d2", "=", 
                    RowBox[{"pp", "[", 
                    RowBox[{"[", "2", "]"}], "]"}]}], ",", 
                    RowBox[{"d3", "=", 
                    RowBox[{"pp", "[", 
                    RowBox[{"[", "3", "]"}], "]"}]}], ",", "du", ",", "dv", ",",
                     "dw"}], "}"}], ",", 
                  RowBox[{
                   RowBox[{"du", "=", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"u1", "-", "u0"}], ")"}], "/", 
                    RowBox[{"(", 
                    RowBox[{"d1", "-", "1"}], ")"}]}]}], ";", 
                   "\[IndentingNewLine]", 
                   RowBox[{"dv", "=", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"v1", "-", "v0"}], ")"}], "/", 
                    RowBox[{"(", 
                    RowBox[{"d2", "-", "1"}], ")"}]}]}], ";", 
                   "\[IndentingNewLine]", 
                   RowBox[{"dw", "=", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"w1", "-", "w0"}], ")"}], "/", 
                    RowBox[{"(", 
                    RowBox[{"d3", "-", "1"}], ")"}]}]}], ";", 
                   "\[IndentingNewLine]", 
                   RowBox[{"aux", "=", 
                    RowBox[{"Table", "[", 
                    RowBox[{
                    RowBox[{"N", "[", 
                    RowBox[{"$P", "[", 
                    RowBox[{"f", ".", "R"}], "]"}], "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"u", ",", "u0", ",", "u1", ",", "du"}], "}"}], ",", 
                    RowBox[{"{", 
