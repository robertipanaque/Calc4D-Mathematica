         RowBox[{"10", ",", "10", ",", "10"}], "}"}]}], ",", 
       RowBox[{"PlotStyle", "->", "Automatic"}], ",", 
       RowBox[{"ShowAxes", "->", "False"}], ",", 
       RowBox[{"AxesLength", "->", "1"}]}], "}"}], "]"}]}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "flist", ",", "n", ",", "styles", ",", "colors", ",", "points", ",", 
      "aux"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"flist", "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Length", "[", 
          RowBox[{"Dimensions", "[", "flisti", "]"}], "]"}], "==", "1"}], ",", 
        RowBox[{"{", "flisti", "}"}], ",", "flisti"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"n", "=", 
      RowBox[{"Length", "[", "flist", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"colors", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"ColorData", "[", "97", "]"}], "[", "i", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "n"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"points", "=", 
      RowBox[{"OptionValue", "[", "PlotPoints", "]"}]}], ";", "\n", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{"!", 
        RowBox[{"ListQ", "[", 
         RowBox[{"First", "[", "points", "]"}], "]"}]}], ",", 
       RowBox[{"points", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"points", ",", "n"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"Length", "[", "points", "]"}], "==", "n"}], ",", 
       RowBox[{"points", "=", "points"}], ",", "True", ",", 
       RowBox[{"points", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{
          RowBox[{"First", "[", "points", "]"}], ",", "n"}], "]"}]}]}], "]"}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"styles", "=", 
      RowBox[{"OptionValue", "[", "PlotStyle", "]"}]}], ";", "\n", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{"!", 
        RowBox[{"ListQ", "[", "styles", "]"}]}], ",", 
       RowBox[{"styles", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"styles", ",", "n"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"Length", "[", "styles", "]"}], "==", "n"}], ",", 
       RowBox[{"styles", "=", "styles"}], ",", "True", ",", 
       "\[IndentingNewLine]", 
       RowBox[{"styles", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{
          RowBox[{"First", "[", "styles", "]"}], ",", "n"}], "]"}]}]}], "]"}],
      ";", "\n", 
     RowBox[{"styles", "=", 
      RowBox[{"MapThread", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"#1", "/.", " ", 
          RowBox[{"Automatic", ":>", "#2"}]}], "&"}], ",", 
        RowBox[{"{", 
         RowBox[{"styles", ",", "colors"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Animate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"R", "=", 
         RowBox[{
          RowBox[{"RotationMatrix", "[", 
           RowBox[{"\[Theta]1", ",", 
            RowBox[{"{", 
