Cell[BoxData[
 RowBox[{
  RowBox[{"ComplexFunctionPlot", "[", 
   RowBox[{"ff_", ",", 
    RowBox[{"{", 
     RowBox[{"z_", ",", "zmin_", ",", "zmax_"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"OptionsPattern", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"PlotPoints", "->", 
        RowBox[{"{", 
         RowBox[{"10", "+", 
          RowBox[{"10", " ", "I"}]}], "}"}]}], ",", 
       RowBox[{"PlotStyle", "->", "Automatic"}], ",", 
       RowBox[{"ShowAxes", "->", "False"}], ",", "\[IndentingNewLine]", 
       RowBox[{"AxesLength", "->", "1"}], ",", 
       RowBox[{"AxesOrigin", "->", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0"}], "}"}]}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<Re(z)\>\"", ",", "\"\<Im(z)\>\"", ",", "\"\<Re(w)\>\"", 
          ",", "\"\<Im(w)\>\""}], "}"}]}], ",", 
       RowBox[{"Epilog", "->", "None"}], ",", 
       RowBox[{"PlotRange", "->", "All"}]}], "}"}], "]"}]}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "functions", ",", "T", ",", "x0", ",", "x1", ",", "y0", ",", "y1", ",", 
      RowBox[{"pp", "=", 
       RowBox[{"OptionValue", "[", "PlotPoints", "]"}]}], ",", "pp0", ",", 
      "pp1", ",", "stepx", ",", "\[IndentingNewLine]", "stepy", ",", "styles",
       ",", "basePointsList", ",", "R", ",", "graphics", ",", 
      "rotatedPoints4D", ",", "points3D", ",", "n", ",", "colors", ",", 
      "opacities", ",", "epilog"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"functions", "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Head", "[", "ff", "]"}], "=!=", "List"}], ",", 
        RowBox[{"{", "ff", "}"}], ",", "ff"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"T", "[", 
       RowBox[{"x_", ",", "y_", ",", "Fz_"}], "]"}], ":=", 
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"s", "=", 
          RowBox[{"x", "+", 
           RowBox[{"I", "*", "y"}]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "y", ",", 
          RowBox[{"Re", "[", 
           RowBox[{"Fz", "/.", " ", 
            RowBox[{"z", "->", "s"}]}], "]"}], ",", 
          RowBox[{"Im", "[", 
